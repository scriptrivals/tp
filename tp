-- ===== MAIN LOOP =====
RunService.Heartbeat:Connect(function(dt)

    -- VOID
    if voidActive then
        local character = player.Character
        if character then
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            local humanoid = character:FindFirstChild("Humanoid")
            if rootPart and humanoid then
                if targetCFrame then rootPart.CFrame = targetCFrame end
                local now = tick()
                if now - lastTeleport >= 0.05 then
                    lastTeleport = now
                    teleportCount = teleportCount + 1
                    local spread = BASE_SPREAD + (teleportCount * SPREAD_STEP)
                    local angle = math.random() * 2 * math.pi
                    local dx = math.cos(angle) * spread
                    local dz = math.sin(angle) * spread
                    local dy = math.random(VOID_MIN_Y, VOID_MAX_Y)
                    targetCFrame = CFrame.new(dx, dy, dz)
                    humanoid.PlatformStand = true
                    rootPart.CFrame = targetCFrame
                    task.defer(function()
                        if humanoid then humanoid.PlatformStand = false end
                    end)
                    voidStatus.Text = string.format("[ TP #%d | Y:%.0f ]", teleportCount, dy)
                end
            end
        end
    end

    -- ORBIT
    if orbitActive then
        local myChar = player.Character
        if not myChar then return end
        local myRoot = myChar:FindFirstChild("HumanoidRootPart")
        local myHuman = myChar:FindFirstChild("Humanoid")
        if not myRoot or not myHuman then return end

        if lockedTarget == nil or not lockedTarget.Character then
            local nearestDist = math.huge
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= player and p.Character then
                    local theirRoot = p.Character:FindFirstChild("HumanoidRootPart")
                    if theirRoot then
                        local dist = (theirRoot.Position - myRoot.Position).Magnitude
                        if dist < nearestDist then
                            nearestDist = dist
                            lockedTarget = p
                        end
                    end
                end
            end
        end

        if lockedTarget and lockedTarget.Character then
            local targetRoot = lockedTarget.Character:FindFirstChild("HumanoidRootPart")
            if targetRoot then
                orbitAngle = orbitAngle + dt * orbitSpeed
                local targetFootY = targetRoot.Position.Y - 3
                local heightOffset = HEIGHT_MAP[orbitMode]
                local center = targetRoot.Position
                local ox = math.cos(orbitAngle) * orbitRadius
                local oz = math.sin(orbitAngle) * orbitRadius
                local newPos = Vector3.new(
                    center.X + ox,
                    targetFootY + heightOffset,
                    center.Z + oz
                )
                myHuman.PlatformStand = true
                myRoot.CFrame = CFrame.new(newPos, Vector3.new(center.X, newPos.Y, center.Z))
                orbitStatus.Text = string.format("[ %s ][ %s ]", orbitMode, lockedTarget.Name)
                orbitStatus.TextColor3 = Color3.fromRGB(220, 100, 255)
            end
        else
            orbitStatus.Text = "[ NO PLAYER FOUND ]"
            orbitStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
        end
    end
end)

-- ===== DRAG (chỉ ở title) =====
local dragging = false
local dragStart = nil
local startPos = nil

local function blockCamera(_, inputState, _)
    if inputState == Enum.UserInputState.Begin then
        return Enum.ContextActionResult.Sink
    end
    return Enum.ContextActionResult.Pass
end

title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
        ContextActionService:BindAction(
            "BlockCameraDrag", blockCamera, false,
            Enum.UserInputType.MouseMovement,
            Enum.UserInputType.Touch
        )
    end
end)

title.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
        ContextActionService:UnbindAction("BlockCameraDrag")
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
       input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)
